# Nonull LLM Configuration / 大模型配置
# SECURITY: Rotate API keys regularly. Never commit real keys.
# 安全提醒：定期更换 API 密钥，切勿提交真实密钥。
#
# Copy to .env and fill in your values / 复制到 .env 并填写你的值

# ── LLM Configuration (Required for agent mode) ──
# LLM 配置（智能体模式必需）
NONULL_LLM_API_KEY=YOUR_API_KEY_HERE
NONULL_LLM_PROVIDER=openai        # openai | anthropic | deepseek | ollama | custom
NONULL_LLM_MODEL=gpt-4o            # model name / 模型名称
NONULL_LLM_API_BASE=https://api.openai.com/v1
NONULL_LLM_MAX_TOKENS=4096
NONULL_LLM_TEMPERATURE=0.2
# Comma-separated fallback model chain — tried in order when the primary model
# fails with a recoverable error (rate limit / server error / bad request).
# 备用模型链（逗号分隔）：主模型遇到可恢复错误时按顺序尝试。
NONULL_LLM_FALLBACK_MODELS=        # e.g. gpt-4o-mini,deepseek-chat

# ── Agent Configuration ──
# 智能体配置
NONULL_AGENT_NAME=Nonull
NONULL_AGENT_MODE=interactive      # interactive | batch | headless
NONULL_AGENT_MAX_ITERATIONS=50
NONULL_AGENT_TIMEOUT_SECONDS=300

# ── Memory Configuration ──
# 记忆配置
NONULL_MEMORY_ENABLED=true
NONULL_MEMORY_BACKEND=in_memory    # in_memory | redis | postgres | chroma
NONULL_MEMORY_WORKING_CAPACITY=20
NONULL_MEMORY_VECTOR_DIM=256

# ── Safety Configuration ──
# 安全配置
NONULL_SAFETY_STRICTNESS=4
NONULL_SAFETY_DENY_FIRST=true
NONULL_SAFETY_MAX_RISK_SCORE=0.7

# ── Web UI Configuration ──
# Web UI 配置
NONULL_WEB_ENABLED=false
NONULL_WEB_HOST=127.0.0.1
NONULL_WEB_PORT=8765

# ── Logging ──
# 日志配置
NONULL_LOG_LEVEL=INFO
NONULL_LOG_FILE=                   # empty = stderr
