# Nonull LLM API key
# Get one from your LLM provider and set it as an environment variable
# Example: export NONULL_LLM_API_KEY="sk-xxxxx"
# NONULL_LLM_API_KEY=

# LLM provider (openai, anthropic, ollama, etc.)
# Default: openai
# NONULL_LLM_PROVIDER=openai

# LLM model name
# Default: gpt-4o
# NONULL_LLM_MODEL=gpt-4o

# LLM API base URL (for self-hosted or proxies)
# Default: depends on provider
# NONULL_LLM_API_BASE=https://api.openai.com/v1
